DATABASE_URL=postgres://postgres:postgres@localhost:5432/payment_gateway?sslmode=disable
REDIS_URL=redis://localhost:6379
PORT=8080
ENV=development
SIGNING_SECRET=dev-secret-change-me
WEBHOOK_URL=

# Webhook signature verification secrets (required in production)
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret
MOMO_WEBHOOK_SECRET=your_momo_webhook_secret

# CORS allowed origins (comma-separated, defaults to localhost in development)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:8080
